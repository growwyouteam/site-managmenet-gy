{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production",
        "SESSION_SECRET": "@session_secret",
        "FRONTEND_URL": "@frontend_url"
    },
    "regions": [
        "bom1"
    ]
}